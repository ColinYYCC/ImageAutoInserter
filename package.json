{
  "name": "imageautoinserter",
  "version": "1.1.1",
  "description": "**图片自动插入工具** - 根据商品编码自动将图片嵌入 Excel 表格",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:vite-only": "electron-vite dev --rendererOnly",
    "dev:e2e": "vite --config vite.e2e.config.ts",
    "build": "electron-vite build && node scripts/build.js sync-version && node scripts/build.js copy-python && node scripts/build.js copy-fonts && node scripts/build.js copy-node-modules",
    "build:main": "electron-vite build --main",
    "build:preload": "electron-vite build --preload",
    "build:renderer": "electron-vite build --renderer",
    "preview": "electron-vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:integration:coverage": "vitest run --config vitest.integration.config.ts --coverage",
    "test:all": "npm run test:run && npm run test:integration",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "dist": "npm run build && electron-builder --mac --win",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "clean": "node scripts/build.js clean-dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/adm-zip": "^0.5.7",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/styled-components": "^5.1.36",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^23.0.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "^1.1.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "7zip-min": "^3.0.1",
    "adm-zip": "^0.5.16",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "html-to-react": "^1.7.0",
    "node-unrar-js": "^1.0.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.3.11",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.imageautoinserter.app",
    "productName": "ImageAutoInserter",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/main/**/*",
      "dist/main/node_modules/**/*",
      "dist/renderer/**/*",
      "package.json",
      "node_modules/exceljs/**/*",
      "node_modules/adm-zip/**/*",
      "node_modules/7zip-min/**/*",
      "node_modules/electron-store/**/*",
      "!**/*.map",
      "!**/__pycache__/**",
      "!**/*.pyc",
      "!**/*.pyo",
      "!**/*.psd",
      "!**/*.ai",
      "!**/*.sketch",
      "!**/*.md",
      "!**/README*",
      "!**/CHANGELOG*",
      "!**/*.test.*",
      "!**/*.spec.*",
      "!**/tests/**",
      "!**/.trae/**",
      "!**/Sample/**",
      "!**/.git/**",
      "!**/.github/**",
      "!**/docs/**",
      "!**/scripts/**"
    ],
    "extraResources": [
      {
        "from": "dist/python",
        "to": "python",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "python/**/*",
      "node_modules/node-unrar-js/**/*",
      "node_modules/7zip-bin/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "include": "build/installer.nsh",
      "displayLanguageSelector": false,
      "runAfterFinish": true,
      "allowElevation": true
    },
    "publish": {
      "provider": "github",
      "owner": "ColinYYCC",
      "repo": "ImageAutoInserter",
      "releaseType": "release"
    }
  }
}
