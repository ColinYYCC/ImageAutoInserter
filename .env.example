# ImageAutoInserter Configuration
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME=ImageAutoInserter
APP_VERSION=0.1.0
DEBUG=False

# GitHub Update Check (optional)
GITHUB_REPO=yourusername/ImageAutoInserter

# Image Settings (pixels)
IMAGE_WIDTH=180
IMAGE_HEIGHT=138

# Processing Settings
MAX_RETRY_ATTEMPTS=3
PROGRESS_UPDATE_INTERVAL=5
